# ============================================
# Highwatch RAG - Environment Configuration
# ============================================

# --- Google Drive ---
# Path to your OAuth 2.0 credentials JSON (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json
# Path where the OAuth token will be cached after first auth
GOOGLE_TOKEN_PATH=token.json
# Comma-separated Google Drive folder IDs to sync (leave empty for root)
GOOGLE_DRIVE_FOLDER_IDS=

# --- LLM Provider ---
# Choose: "openai" or "gemini"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# --- Embedding ---
# SentenceTransformer model name
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DIMENSION=384

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_CHUNK_SIZE=50

# --- Search ---
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# --- Storage ---
STORAGE_DIR=./storage
FAISS_INDEX_PATH=./storage/faiss_index
DOCUMENTS_DB_PATH=./storage/documents.json

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
